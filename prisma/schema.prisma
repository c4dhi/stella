// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                         String              @id @default(uuid())
  email                      String              @unique
  password                   String              // bcrypt hashed
  name                       String?
  verified                   Boolean             @default(false)
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt
  projectMemberships         ProjectMembership[]
  customAgentTypes           AgentType[]         // Custom agents uploaded by this user
  planTemplates              PlanTemplate[]      // Plan templates created by this user
  envVarTemplates            EnvVarTemplate[]    // Environment variable templates created by this user
  messages                   UserMessage[]       // Inbox messages for this user
  sentProjectInvitations     ProjectInvitation[] @relation("SentInvitations")
  receivedProjectInvitations ProjectInvitation[] @relation("ReceivedInvitations")
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

model ProjectMembership {
  id        String     @id @default(uuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role      MemberRole @default(MEMBER)
  createdAt DateTime   @default(now())

  @@unique([userId, projectId])
  @@index([userId])
  @@index([projectId])
}

model Project {
  id          String              @id @default(uuid())
  name        String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  sessions    Session[]
  memberships ProjectMembership[]

  // Public Project Configuration
  isPublic               Boolean    @default(false)
  publicToken            String?    @unique @default(uuid())
  publicAgentTypeId      String?
  publicAgentType        AgentType? @relation(fields: [publicAgentTypeId], references: [id], name: "publicProjects")
  publicAgentConfig      Json?      // { name, icon, plan, envVarTemplateId }
  publicVisualizerType   String?
  publicVisualizerLocked Boolean    @default(false)
  publicExpiresAt        DateTime?
  publicEnabled          Boolean    @default(true)

  // Project collaboration invitations
  projectInvitations ProjectInvitation[]

  @@index([publicToken])
  @@index([isPublic, publicEnabled])
}

enum SessionStatus {
  ACTIVE
  CLOSED
}

enum InvitationStatus {
  PENDING   // Created, waiting for participant
  ACCEPTED  // Participant joined
  EXPIRED   // Time-based expiration
  REVOKED   // Manually revoked by organizer
}

model Session {
  id           String          @id @default(uuid())
  projectId    String
  project      Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name         String?
  status       SessionStatus   @default(ACTIVE)
  createdAt    DateTime        @default(now())
  closedAt     DateTime?
  room         Room?
  agents       AgentInstance[]
  participants Participant[]
  invitations  Invitation[]
  messages     Message[]
  events       RoomEvent[]
  state        SessionState?   // State machine execution state

  // Message-recorder optimization: webhook-driven room management
  hasHumanParticipant    Boolean   @default(false)  // True when human is in room
  humanJoinedAt          DateTime?                   // When first human joined
  humanLeftAt            DateTime?                   // When last human left
  recorderShouldJoin     Boolean   @default(false)  // True when recorder should be in room

  // Agent pausing: on-demand spawning for resource optimization
  agentSpawnMode         String    @default("immediate")  // 'immediate' | 'on_demand'
  lastAgentConfig        Json?                            // Stored config for respawning paused agents

  @@index([projectId])
  @@index([status])
  @@index([createdAt])
  @@index([recorderShouldJoin])
}

// State machine execution state for conversation progress tracking
// Persists the plan execution state externally from agents
model SessionState {
  id                   String   @id @default(uuid())
  sessionId            String   @unique
  session              Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // Plan data
  planId               String?  // Reference to plan ID
  planData             Json     // Full plan definition (states, tasks, deliverables)

  // Current execution state
  currentStateId       String   // Current state in the plan
  completedTasks       String[] @default([]) // Task IDs that have been completed
  skippedTasks         String[] @default([]) // Task IDs that were skipped

  // Collected deliverables
  deliverables         Json     @default("{}") // { key: { value, reasoning, collectedAt } }

  // Progress tracking
  turnsWithoutProgress Int      @default(0) // Turns since last deliverable/task completion
  totalTurns           Int      @default(0) // Total conversation turns

  // Timestamps
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  lastTransitionAt     DateTime? // When state last changed

  @@index([sessionId])
  @@index([planId])
}

model Room {
  id              String  @id @default(uuid())
  sessionId       String  @unique
  session         Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  livekitRoomName String  @unique
  serverUrl       String
}

enum AgentStatus {
  STARTING
  RUNNING
  STOPPING
  STOPPED
  FAILED
}

enum AgentValidationStatus {
  PENDING
  APPROVED
  REJECTED
}

// Agent type registry - supports built-in and custom agents
model AgentType {
  id               String    @id @default(uuid())
  slug             String    @unique  // e.g., "stella-agent", "echo-agent", "memory-coach"
  name             String              // Display name: "Stella Agent"
  description      String              // Short description for gallery card
  icon             String?             // Default emoji or image URL
  version          String    @default("1.0.0")

  // Built-in vs custom
  isBuiltIn        Boolean   @default(true)

  // Ownership (for custom agents)
  userId           String?             // Owner of custom agent (null for built-in)
  user             User?     @relation(fields: [userId], references: [id])

  // Package storage (for custom agents with uploaded zip)
  packagePath      String?             // Local filesystem path to stored zip
  packageSize      Int?                // Size in bytes
  packageHash      String?             // SHA256 hash for integrity

  // Image configuration
  imageUrl         String?             // Pre-built Docker image URL (e.g., ghcr.io/org/agent:v1)
  dockerfilePath   String?             // Path to Dockerfile within package (default: "Dockerfile")

  // Validation workflow
  validationStatus AgentValidationStatus @default(PENDING)
  validationNotes  String?             // Reviewer notes (for rejection reasons)
  validatedAt      DateTime?           // When validation decision was made
  validatedBy      String?             // Admin user ID who validated

  // Config schema (JSON Schema format for UI)
  configSchema     Json?               // JSON Schema defining available config options
  capabilities     Json?               // e.g., ["voice", "text", "progress"]
  defaultConfig    Json?               // Default config for this agent type

  // Resource limits
  resourceMemory   String?   @default("512Mi")   // Memory limit (e.g., "512Mi", "2Gi")
  resourceCpu      String?   @default("250m")    // CPU limit (e.g., "250m", "1000m")
  resourceGpu      Boolean   @default(false)     // Whether GPU is required

  // Author info (for custom agents)
  authorName       String?             // Author display name
  authorEmail      String?             // Author contact email
  tags             Json?               // Array of tags for filtering

  // SDK requirements
  sdkMinVersion    String?             // Minimum stella-ai-agent-sdk version

  // Timestamps
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  agents           AgentInstance[]
  buildLogs        AgentBuildLog[]
  envVarTemplates  EnvVarTemplate[]    // Env var templates scoped to this agent type
  publicProjects   Project[]           @relation(name: "publicProjects")

  @@index([slug])
  @@index([isBuiltIn])
  @@index([userId])
  @@index([validationStatus])
}

model AgentInstance {
  id            String       @id @default(uuid())
  sessionId     String
  session       Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name          String       // Agent name (required)
  icon          String?      // Optional emoji icon (default: 🤖)
  status        AgentStatus  @default(STARTING)
  podName       String?
  secretName    String?
  configMapName String?
  agentConfig   Json?        // Agent-specific config (e.g., { plan_id: "stella_smalltalk" })
  agentType     String?      @default("stella-agent")  // Agent type slug for backward compat
  agentTypeId   String?                               // FK to AgentType (optional for backward compat)
  agentTypeRef  AgentType?   @relation(fields: [agentTypeId], references: [id])
  createdAt     DateTime     @default(now())
  stoppedAt     DateTime?

  // Environment variable template (for API keys like OPENAI_API_KEY)
  envVarTemplateId String?
  envVarTemplate   EnvVarTemplate? @relation(fields: [envVarTemplateId], references: [id])

  // Health tracking (Phase 3.2)
  healthState       String?   @default("unknown")  // Agent state: initializing, ready, processing, error, etc.
  lastHealthCheck   DateTime?                      // Last time health check was performed
  lastError         String?                        // Last error message from agent
  messagesProcessed Int       @default(0)          // Number of messages processed by agent
  grpcAddress       String?                        // gRPC address for agent connection (e.g., "agent-pod:50051")

  // Agent pausing: on-demand lifecycle management
  pausedAt          DateTime?                      // When agent was paused due to inactivity
  pauseReason       String?                        // 'inactivity' | 'manual'
  resumeCount       Int       @default(0)          // Number of times agent has been resumed

  @@index([sessionId])
  @@index([status])
  @@index([agentTypeId])
  @@index([envVarTemplateId])
}

model Participant {
  id                   String      @id @default(uuid())
  sessionId            String
  session              Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name                 String      // Display name for the participant
  identity             String      // LiveKit identity (auto-generated)
  isManuallyRegistered Boolean     @default(false) // True if registered via API, false if auto-discovered
  joinedAt             DateTime    @default(now())
  leftAt               DateTime?
  tokenRevokedAt       DateTime?   // When token was revoked (soft delete for security)
  lastTokenRefresh     DateTime?   // Last time LiveKit token was refreshed
  lastSeenAt           DateTime?   // Last presence update from LiveKit
  invitation           Invitation? // Link to invitation if created via invitation flow

  @@index([sessionId])
  @@index([identity])
}

// Invitation for participants to join sessions via shareable link
model Invitation {
  id              String           @id @default(uuid())
  sessionId       String
  session         Session          @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // Invitation details
  token           String           @unique @default(uuid()) // URL token for /join/:token
  participantName String           // Pre-assigned name for the participant
  customMessage   String?          @db.Text // Optional organizer message

  // Avatar/visualizer settings
  visualizerType  String?          // e.g., "sphere", "face", "galaxy", "rainy", "snowy", "christmas", "sunny"
  visualizerLocked Boolean         @default(false) // If true, participant can't change visualizer

  // Status tracking
  status          InvitationStatus @default(PENDING)
  createdAt       DateTime         @default(now())
  expiresAt       DateTime?        // Organizer-configured expiration (null = indefinite)
  acceptedAt      DateTime?        // When participant accepted and joined

  // Link to created participant (set when invitation is accepted)
  participantId   String?          @unique
  participant     Participant?     @relation(fields: [participantId], references: [id])

  @@index([sessionId])
  @@index([token])
  @@index([status])
}

model Message {
  id            String       @id @default(uuid())
  sessionId     String
  session       Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // Message content and metadata
  content       String       @db.Text
  messageType   String       // "transcript", "system", "task_update", "deliverable", "state_change", "participant_event"
  role          String?      // "user", "assistant", "system"
  status        String?      // "partial", "final"
  metadata      Json?        // Store complete envelope with participant info, deliverables, processing messages, etc.

  timestamp     DateTime     @default(now())
  createdAt     DateTime     @default(now())

  @@index([sessionId])
  @@index([sessionId, timestamp])
  @@index([messageType])
  @@index([timestamp])
}

model RoomEvent {
  id        String   @id @default(uuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  eventType String
  data      Json
  timestamp DateTime @default(now())

  @@index([sessionId])
  @@index([eventType])
  @@index([timestamp])
}

// Build log for custom agent Docker image builds
model AgentBuildLog {
  id            String      @id @default(uuid())
  agentTypeId   String
  agentType     AgentType   @relation(fields: [agentTypeId], references: [id], onDelete: Cascade)

  // Build status
  status        String      // "pending", "building", "success", "failed"
  imageName     String?     // Final image name (e.g., "memory-coach:1.0.0")

  // Build output
  buildOutput   String?     @db.Text  // Full build log output
  errorMessage  String?               // Error message if failed

  // Timing
  startedAt     DateTime    @default(now())
  completedAt   DateTime?

  @@index([agentTypeId])
  @@index([status])
  @@index([startedAt])
}

// Plan template for reusable agent conversation plans
model PlanTemplate {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?  @db.Text
  content     Json     // Canonical SDK format: { states: [...], system_prompt?: string, session_context?: { fields: [...] } }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// Environment variable template for reusable secure configurations
model EnvVarTemplate {
  id          String     @id @default(uuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  description String?    @db.Text

  // Encrypted JSON: { "KEY": "value", ... }
  // Values are encrypted at rest using AES-256-GCM
  // Format: {iv}:{authTag}:{encryptedData} (all base64 encoded)
  variables   String     @db.Text

  // Optional: scope to specific agent type
  agentTypeId String?
  agentType   AgentType? @relation(fields: [agentTypeId], references: [id])

  // Agents using this template
  agents      AgentInstance[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId])
  @@index([agentTypeId])
}

// ============================================================================
// User Messaging System
// ============================================================================

// Message types for user inbox
enum UserMessageType {
  PROJECT_INVITATION // Invitation to collaborate on a project
  // Future: SYSTEM_ANNOUNCEMENT, PROJECT_UPDATE, etc.
}

// Project collaboration invitation status
enum ProjectInvitationStatus {
  PENDING  // Waiting for response
  ACCEPTED // User accepted the invitation
  DECLINED // User declined the invitation
}

// Generic user inbox message
model UserMessage {
  id        String          @id @default(uuid())
  userId    String          // Recipient
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      UserMessageType
  title     String
  body      String?         @db.Text
  read      Boolean         @default(false)
  createdAt DateTime        @default(now())

  // Polymorphic reference to related entity
  relatedEntityId   String?
  relatedEntityType String? // "ProjectInvitation", etc.

  @@index([userId])
  @@index([userId, read])
  @@index([createdAt])
}

// Project collaboration invitation
model ProjectInvitation {
  id          String                  @id @default(uuid())
  projectId   String
  project     Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inviterId   String                  // User who sent the invitation
  inviter     User                    @relation("SentInvitations", fields: [inviterId], references: [id])
  inviteeId   String                  // User being invited
  invitee     User                    @relation("ReceivedInvitations", fields: [inviteeId], references: [id])
  status      ProjectInvitationStatus @default(PENDING)
  createdAt   DateTime                @default(now())
  respondedAt DateTime?

  @@unique([projectId, inviteeId]) // One invitation per user per project
  @@index([inviteeId, status])
  @@index([projectId])
}
