# ============================================================================
# STELLA - ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
# Copy this file to .env.local (for local dev) or .env.production (for prod)
# Each file is self-contained — no base .env file is used
# Derived variables (URLs, ports, etc.) are set automatically by scripts
# ============================================================================

# ============================================================================
# ENVIRONMENT
# ============================================================================
# "local" = Development with localhost URLs
# "production" = Production deployment with custom domain
NODE_ENV=local

# Production domain (only used when NODE_ENV=production)
# Example: yourdomain.com → frontend.yourdomain.com, backend.yourdomain.com
PRODUCTION_DOMAIN=yourdomain.com

# ============================================================================
# DATABASE
# ============================================================================
POSTGRES_DB=session_management
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-db-password

# Direct connection URL (for local psql/migrations)
DATABASE_URL="postgresql://postgres:your-secure-db-password@localhost:5432/session_management?schema=public"

# ============================================================================
# SECURITY
# ============================================================================
# JWT secret (64+ characters recommended)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Environment variable encryption key (REQUIRED in production)
# Used to encrypt sensitive environment variables stored in the database
# Generate with: openssl rand -hex 32
# Must be exactly 64 hex characters (32 bytes)
# WARNING: Losing this key means losing access to all encrypted env vars!
ENV_VAR_ENCRYPTION_KEY=

# ============================================================================
# LIVEKIT (WebRTC Server)
# ============================================================================
# Two separate URLs for internal and external access:
#
# LIVEKIT_URL: Internal connection for services in K8s pods
#   - Local: ws://localhost:7880 (Docker LiveKit)
#   - Production: ws://host.minikube.internal:7880 (host LiveKit)
#
# PUBLIC_LIVEKIT_URL: External connection for browsers
#   - Local: ws://localhost:7880 (same as internal)
#   - Production: wss://livekit.yourdomain.com (through Caddy)
LIVEKIT_URL=ws://localhost:7880
PUBLIC_LIVEKIT_URL=ws://localhost:7880

# LiveKit credentials
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# TURN server (for NAT traversal in production)
LIVEKIT_TURN_ENABLED=false
LIVEKIT_TURN_DOMAIN=turn.yourdomain.com

# ============================================================================
# KUBERNETES DNS CONFIGURATION
# ============================================================================
# Custom DNS servers for CoreDNS (space-separated list)
# Use this to bypass network DNS interception (e.g., corporate SSL inspection)
# Examples:
#   CUSTOM_DNS_SERVERS="8.8.8.8 8.8.4.4"    # Google DNS (recommended for production)
#   CUSTOM_DNS_SERVERS="1.1.1.1 1.0.0.1"    # Cloudflare DNS
#   CUSTOM_DNS_SERVERS=""                    # Use system default DNS (local dev)
CUSTOM_DNS_SERVERS=""

# Kubernetes DNS Configuration
# IMPORTANT: Custom DNS config is ONLY used in production mode
# Local development uses default Kubernetes DNS and doesn't need these settings
#
# Production mode sets custom DNS to bypass network DNS hijacking:
#   - Excludes problematic search domains (e.g., cloud.science-it.uzh.ch)
#   - Sets ndots:2 to prevent search domain appending
#
# AUTO_DETECT_K8S_DNS: Auto-detect CoreDNS IP in production (set to true in .env.production)
# KUBERNETES_DNS_NAMESERVER: Fallback DNS IP (not used in local mode)
AUTO_DETECT_K8S_DNS=false
KUBERNETES_DNS_NAMESERVER="10.96.0.10"

# ============================================================================
# AI APIs
# ============================================================================
# OpenAI API key (used by agents for conversation)
OPENAI_API_KEY=sk-your-openai-api-key

# OpenAI API key for Plan Generator AI (separate from agent key for cost isolation)
# Used to generate plan templates from natural language descriptions
OPENAI_PLAN_GENERATOR_API_KEY=sk-your-plan-generator-api-key

# ============================================================================
# GPU ACCELERATION
# ============================================================================
# Enable GPU support for STT and TTS services
# Set to "true" to build GPU-enabled images with CUDA support (~2GB)
# Set to "false" for lightweight CPU-only images (~500MB)
#
# GPU mode requires:
#   - Linux with NVIDIA GPU (Tesla T4, RTX 3000+, etc.)
#   - NVIDIA drivers installed (nvidia-smi should work)
#   - K3s with NVIDIA Container Toolkit
#
# On macOS: Automatically falls back to CPU mode (no NVIDIA support)
ENABLE_GPU=false

# ============================================================================
# TEXT-TO-SPEECH (TTS) PROVIDER
# ============================================================================
# TTS Provider options:
#   - piper:       Fast local TTS (CPU, 30-80ms latency, multi-language voices)
#                  REQUIRES ENABLE_PIPER=true at build time (GPL-3.0 opt-in)
#   - kokoro:      Fast local TTS (50-100ms latency, GPU-accelerated, English only)
#   - chatterbox:  Local multilingual TTS (EN/DE, GPU recommended, ~2GB model)
#   - voxtral:     Local Voxtral 4B TTS (GPU recommended). Opt-in only —
#                  requires ENABLE_VOXTRAL=true at build time AND operator-
#                  supplied weights at VOXTRAL_MODEL_PATH. The model weights
#                  are CC-BY-NC-4.0 (non-commercial); STELLA does not ship them.
#   - elevenlabs:  Best quality cloud TTS (200-300ms latency, costs apply)
#   - auto:        Automatic fallback (piper → chatterbox → kokoro)
#
# Note: When ENABLE_GPU=true, kokoro is auto-selected for best performance
TTS_PROVIDER=piper

# Piper TTS is licensed under GPL-3.0 (via its espeak-ng dependency) and is
# therefore shipped as an opt-in build component, so the default image stays
# permissively licensed. Set ENABLE_PIPER=true to include Piper in the
# tts-service image build. The internal deploy script defaults to true.
ENABLE_PIPER=true

# Voxtral TTS is opt-in. Setting ENABLE_VOXTRAL=true installs the (Apache-2.0)
# inference dependencies, but STELLA never downloads or ships the model
# weights — they are CC-BY-NC-4.0 and must be obtained by the operator. The
# provider only activates when both ENABLE_VOXTRAL=true AND VOXTRAL_MODEL_PATH
# point at a directory the operator has populated themselves.
ENABLE_VOXTRAL=false

# TTS Enable/Disable (Agent SDK)
# Set to "false" to disable TTS entirely in the agent SDK.
# The agent will still receive speech input (STT) and send text responses,
# but no audio will be synthesized — effectively a text-only chatbot mode.
TTS_ENABLED=true

# TTS Language (ISO 639-1 code)
# Used by agents to set default language for TTS synthesis
# Agents can also override per-call via speak(language="de")
# Leave empty to use provider default (English)
TTS_LANGUAGE=

# ElevenLabs API key (only needed if TTS_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ONNX Runtime Provider (for STT and TTS GPU acceleration)
# Used by Sherpa-ONNX (STT) and Kokoro (TTS) for GPU inference
#
# Options:
#   - CUDAExecutionProvider,CPUExecutionProvider: Try GPU first, fall back to CPU
#   - CPUExecutionProvider: CPU only (for macOS or when no GPU available)
#
# Note: This is auto-configured based on ENABLE_GPU setting
# When ENABLE_GPU=true on Linux: Uses CUDAExecutionProvider
# When ENABLE_GPU=false or on macOS: Uses CPUExecutionProvider
ONNX_PROVIDER=CUDAExecutionProvider,CPUExecutionProvider

# ============================================================================
# SPEECH-TO-TEXT (STT) PROVIDER
# ============================================================================
# STT Provider options:
#   - sherpa:  Lightweight CPU model (~180MB, fast startup, good for dev)
#   - whisper: GPU-accelerated model (large-v3 ~3GB, best accuracy)
#
# Note: When ENABLE_GPU=true, whisper is auto-selected for best quality
STT_PROVIDER=sherpa

# faster-whisper Configuration (only used when STT_PROVIDER=whisper)
# Models:
#   - English-only: tiny.en, base.en, small.en, medium.en (faster, smaller)
#   - Multilingual: tiny, base, small, medium, large-v3 (best accuracy, ~3GB)
# Note: Use multilingual models (without .en suffix) for multi-language support
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=5
# Language: Empty for auto-detect (supports German, English, 90+ languages)
# Set to specific code (de, en, fr, etc.) to force single language (faster)
WHISPER_LANGUAGE=

# ============================================================================
# WHISPER-SPECIFIC VAD CONFIGURATION (Silero VAD - neural network based)
# Only applies when STT_PROVIDER=whisper
# ============================================================================
VAD_THRESHOLD=0.5                    # Speech detection threshold (0-1, higher = stricter)
VAD_SILENCE_DURATION_MS=800          # Silence before entering MAYBE_ENDING state (ms)
VAD_CONTINUATION_WINDOW_MS=1000      # Time in MAYBE_ENDING for speech to resume (ms)
VAD_MAX_ENDPOINTING_DELAY_MS=2000    # Hard cutoff for max endpointing delay (ms)
VAD_MIN_SPEECH_MS=500                # Minimum speech duration before valid utterance (ms)
VAD_MAX_SPEECH_DURATION_MS=30000     # Force endpoint after this duration of speech (ms)
VAD_AUDIO_INACTIVITY_TIMEOUT_MS=1500 # Force endpoint if no audio arrives during speech (ms)
VAD_RMS_THRESHOLD=0.008              # Energy gate for filtering background noise (0.01=-40dB)
PARTIAL_INTERVAL_MS=1000             # How often to emit partial transcripts (ms)

# ============================================================================
# SHERPA-SPECIFIC VAD CONFIGURATION (RMS-based - energy detection)
# Only applies when STT_PROVIDER=sherpa
# ============================================================================
SHERPA_SILENCE_THRESHOLD=1.5    # Seconds of silence before end-of-speech
SHERPA_SPEECH_TIMEOUT=10.0      # Force endpoint after this many seconds
SHERPA_RMS_THRESHOLD=0.001      # Audio energy threshold for speech detection
SHERPA_PRE_BUFFER_SAMPLES=8000  # Pre-buffer samples (0.5s at 16kHz)
SHERPA_MIN_TRANSCRIPT_CHARS=3   # Minimum characters for valid transcript

# ============================================================================
# PIPELINE-LEVEL TRANSCRIPT DEBOUNCING (Secondary Defense)
# ============================================================================
# Aggregates rapid successive final transcripts within this window (ms)
# Set to 0 to disable debouncing (rely only on STT-level filtering)
TRANSCRIPT_DEBOUNCE_MS=300

# ============================================================================
# TEXT-TO-SPEECH (TTS) - ElevenLabs Settings
# ============================================================================
# ChatterBox settings (only used when TTS_PROVIDER=chatterbox)
CHATTERBOX_LANGUAGE=en                  # Default language: en, de
CHATTERBOX_EXAGGERATION=0.5            # Emotion intensity (0.0-1.0)
CHATTERBOX_CFG_WEIGHT=0.5              # Generation guidance (0.0-1.0)
# CHATTERBOX_AUDIO_PROMPT=             # Optional: path to ~10s reference audio for voice cloning
# CHATTERBOX_DEVICE=auto               # auto, cuda, cpu, mps

# ElevenLabs voice settings (only used when TTS_PROVIDER=elevenlabs)
ELEVENLABS_VOICE_ID=Xb7hH8MSUJpSbSDYk0k2
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# Voxtral settings (only used when TTS_PROVIDER=voxtral and ENABLE_VOXTRAL=true)
# HuggingFace access token (hf_...). Required to download the gated Voxtral
# weights from the init container. Click "Agree and access repository" on
# https://huggingface.co/mistralai/Voxtral-4B-TTS-2603 first, then mint a
# read-scoped token at https://huggingface.co/settings/tokens.
HF_TOKEN=
# Path to a directory the operator populated with Voxtral weights (e.g. via
# `huggingface-cli download mistralai/Voxtral-4B-TTS-2603 --local-dir ...`).
# Setting this path constitutes acceptance of the model's CC-BY-NC-4.0 license,
# including the prohibition on commercial use. STELLA never downloads these
# weights itself.
# VOXTRAL_MODEL_PATH=/models/voxtral-4b-tts
# VOXTRAL_DEVICE=auto                    # auto, cuda, cpu, mps
# VOXTRAL_DTYPE=auto                     # auto (per-device), bfloat16, float16, float32
# VOXTRAL_SAMPLE_RATE=24000              # Output sample rate (Hz)
# Load-time quantization via bitsandbytes (CUDA only). Recommended for tight
# VRAM (e.g. Tesla T4 16GB shared with STT). Leave both at false on L4/A100/etc.
VOXTRAL_LOAD_IN_4BIT=false              # ~2.5GB VRAM; nf4 + bf16 compute, near-zero quality loss
VOXTRAL_LOAD_IN_8BIT=false              # ~5GB VRAM; slower than 4bit, marginally higher quality
# VOXTRAL_4BIT_QUANT_TYPE=nf4            # nf4 (recommended) or fp4

# ============================================================================
# STORAGE CONFIGURATION
# ============================================================================
# Temporary directory for build artifacts, logs, and Docker image exports
# Set this to a separate volume (e.g., /mnt/stella-ai-temp) when root filesystem
# has limited space. Default: /tmp
#
# This directory is used for:
#   - Docker build logs
#   - K3s image import/export (can be several GB)
#   - Temporary K8s manifests
#   - PID files for daemon mode
#
# Example for production with external volume:
#   STELLA_AI_TEMP_DIR=/mnt/stella-ai-temp
STELLA_AI_TEMP_DIR=
