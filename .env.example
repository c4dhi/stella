# ============================================================================
# GRACE AI - ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
# Copy this file to .env and fill in your values
# This file contains ONLY user-configurable variables
# Derived variables (URLs, ports, etc.) are set automatically by scripts
# ============================================================================

# ============================================================================
# ENVIRONMENT
# ============================================================================
# "local" = Development with localhost URLs
# "production" = Production deployment with custom domain
NODE_ENV=local

# Production domain (only used when NODE_ENV=production)
# Example: yourdomain.com → frontend.yourdomain.com, backend.yourdomain.com
PRODUCTION_DOMAIN=yourdomain.com

# ============================================================================
# DATABASE
# ============================================================================
POSTGRES_DB=session_management
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-db-password

# Direct connection URL (for local psql/migrations)
DATABASE_URL="postgresql://postgres:your-secure-db-password@localhost:5432/session_management?schema=public"

# ============================================================================
# SECURITY
# ============================================================================
# JWT secret (64+ characters recommended)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ============================================================================
# LIVEKIT (WebRTC Server)
# ============================================================================
# Two separate URLs for internal and external access:
#
# LIVEKIT_URL: Internal connection for services in K8s pods
#   - Local: ws://localhost:7880 (Docker LiveKit)
#   - Production: ws://host.minikube.internal:7880 (host LiveKit)
#
# PUBLIC_LIVEKIT_URL: External connection for browsers
#   - Local: ws://localhost:7880 (same as internal)
#   - Production: wss://livekit.yourdomain.com (through Caddy)
LIVEKIT_URL=ws://localhost:7880
PUBLIC_LIVEKIT_URL=ws://localhost:7880

# LiveKit credentials
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# TURN server (for NAT traversal in production)
LIVEKIT_TURN_ENABLED=false
LIVEKIT_TURN_DOMAIN=turn.yourdomain.com

# ============================================================================
# KUBERNETES DNS CONFIGURATION
# ============================================================================
# Custom DNS servers for CoreDNS (space-separated list)
# Use this to bypass network DNS interception (e.g., corporate SSL inspection)
# Examples:
#   CUSTOM_DNS_SERVERS="8.8.8.8 8.8.4.4"    # Google DNS (recommended for production)
#   CUSTOM_DNS_SERVERS="1.1.1.1 1.0.0.1"    # Cloudflare DNS
#   CUSTOM_DNS_SERVERS=""                    # Use system default DNS (local dev)
CUSTOM_DNS_SERVERS=""

# Kubernetes DNS Configuration
# IMPORTANT: Custom DNS config is ONLY used in production mode
# Local development uses default Kubernetes DNS and doesn't need these settings
#
# Production mode sets custom DNS to bypass network DNS hijacking:
#   - Excludes problematic search domains (e.g., cloud.science-it.uzh.ch)
#   - Sets ndots:2 to prevent search domain appending
#
# AUTO_DETECT_K8S_DNS: Auto-detect CoreDNS IP in production (set to true in .env.production)
# KUBERNETES_DNS_NAMESERVER: Fallback DNS IP (not used in local mode)
AUTO_DETECT_K8S_DNS=false
KUBERNETES_DNS_NAMESERVER="10.96.0.10"

# ============================================================================
# AI APIs
# ============================================================================
# OpenAI API key
OPENAI_API_KEY=sk-your-openai-api-key

# ============================================================================
# GPU ACCELERATION
# ============================================================================
# Enable GPU support for STT and TTS services
# Set to "true" to build GPU-enabled images with CUDA support (~2GB)
# Set to "false" for lightweight CPU-only images (~500MB)
#
# GPU mode requires:
#   - Linux with NVIDIA GPU (Tesla T4, RTX 3000+, etc.)
#   - NVIDIA drivers installed (nvidia-smi should work)
#   - K3s with NVIDIA Container Toolkit
#
# On macOS: Automatically falls back to CPU mode (no NVIDIA support)
ENABLE_GPU=false

# ============================================================================
# TEXT-TO-SPEECH (TTS) PROVIDER
# ============================================================================
# TTS Provider options:
#   - kokoro:      Fast local TTS (50-100ms latency, GPU-accelerated if ENABLE_GPU=true)
#   - elevenlabs:  Best quality cloud TTS (200-300ms latency, costs apply)
#   - edge_tts:    Free cloud TTS from Microsoft (200-300ms latency)
#   - auto:        Automatic fallback (kokoro → elevenlabs → edge_tts)
#
# Note: When ENABLE_GPU=true, kokoro is auto-selected for best performance
TTS_PROVIDER=edge_tts

# ElevenLabs API key (only needed if TTS_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ONNX Runtime Provider (for STT and TTS GPU acceleration)
# Used by Sherpa-ONNX (STT) and Kokoro (TTS) for GPU inference
#
# Options:
#   - CUDAExecutionProvider,CPUExecutionProvider: Try GPU first, fall back to CPU
#   - CPUExecutionProvider: CPU only (for macOS or when no GPU available)
#
# Note: This is auto-configured based on ENABLE_GPU setting
# When ENABLE_GPU=true on Linux: Uses CUDAExecutionProvider
# When ENABLE_GPU=false or on macOS: Uses CPUExecutionProvider
ONNX_PROVIDER=CUDAExecutionProvider,CPUExecutionProvider

# ============================================================================
# PYTHON AGENT - SPEECH-TO-TEXT (STT)
# ============================================================================
# STT Provider: "sherpa" (lightweight) or "faster-whisper" (accurate)
STT_PROVIDER=sherpa

# Whisper model (if using faster-whisper): tiny.en, base.en, small.en, medium.en
WHISPER_MODEL=base.en

# VAD (Voice Activity Detection) threshold
VAD_THRESHOLD=0.5

# ============================================================================
# PYTHON AGENT - TEXT-TO-SPEECH (TTS)
# ============================================================================
# ElevenLabs voice settings (only if TTS_PROVIDER=elevenlabs)
ELEVENLABS_VOICE_ID=Xb7hH8MSUJpSbSDYk0k2
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
