# ============================================================================
# GRACE AI - ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
# Copy this file to .env and fill in your values
# This file contains ONLY user-configurable variables
# Derived variables (URLs, ports, etc.) are set automatically by scripts
# ============================================================================

# ============================================================================
# ENVIRONMENT
# ============================================================================
# "local" = Development with localhost URLs
# "production" = Production deployment with custom domain
NODE_ENV=local

# Production domain (only used when NODE_ENV=production)
# Example: yourdomain.com → frontend.yourdomain.com, backend.yourdomain.com
PRODUCTION_DOMAIN=yourdomain.com

# ============================================================================
# DATABASE
# ============================================================================
POSTGRES_DB=session_management
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-db-password

# Direct connection URL (for local psql/migrations)
DATABASE_URL="postgresql://postgres:your-secure-db-password@localhost:5432/session_management?schema=public"

# ============================================================================
# SECURITY
# ============================================================================
# JWT secret (64+ characters recommended)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ============================================================================
# LIVEKIT (WebRTC Server)
# ============================================================================
# LiveKit URL (used by all services - backend, frontend, agents)
# For local Docker LiveKit: ws://localhost:7880
# For external server: wss://livekit.yourdomain.com
LIVEKIT_URL=ws://localhost:7880

# LiveKit credentials
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# TURN server (for NAT traversal in production)
LIVEKIT_TURN_ENABLED=false
LIVEKIT_TURN_DOMAIN=turn.yourdomain.com

# ============================================================================
# AI APIs
# ============================================================================
# OpenAI API key
OPENAI_API_KEY=sk-your-openai-api-key

# TTS Provider: "opensource" (Kokoro) or "elevenlabs" (cloud)
TTS_PROVIDER=opensource

# ElevenLabs API key (only needed if TTS_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ============================================================================
# PYTHON AGENT - SPEECH-TO-TEXT (STT)
# ============================================================================
# STT Provider: "sherpa" (lightweight) or "faster-whisper" (accurate)
STT_PROVIDER=sherpa

# Whisper model (if using faster-whisper): tiny.en, base.en, small.en, medium.en
WHISPER_MODEL=base.en

# VAD (Voice Activity Detection) threshold
VAD_THRESHOLD=0.5

# ============================================================================
# PYTHON AGENT - TEXT-TO-SPEECH (TTS)
# ============================================================================
# ElevenLabs voice settings (only if TTS_PROVIDER=elevenlabs)
ELEVENLABS_VOICE_ID=Xb7hH8MSUJpSbSDYk0k2
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
