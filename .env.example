# Database (local development)
DATABASE_URL="postgresql://user:password@localhost:5432/session_management?schema=public"

# Database Credentials for Kubernetes deployment
POSTGRES_DB=session_management
POSTGRES_USER=your-db-username
POSTGRES_PASSWORD=your-secure-db-password

# Server
PORT=3000
NODE_ENV=development

# API Prefix Configuration
# API prefix is DISABLED - all routes are at root level
# Routes: /health, /auth/login, /projects, etc. (NOT /api/*)
# API_PREFIX is set to empty string by default
API_PREFIX=

# CORS Configuration
# Controls which origins can access the API
# - development: defaults to * (all origins)
# - production: should be set to your domain
# Examples:
# CORS_ORIGIN=https://yourdomain.com
# CORS_ORIGIN=https://c4dhi.moserfelix.com
# CORS_ORIGIN=*

# Public Domain/IP (used for all external URLs)
# Examples:
# PUBLIC_DOMAIN=130.60.9.82  (for IP-based access)
# PUBLIC_DOMAIN=yourdomain.com  (for domain-based access)
PUBLIC_DOMAIN=localhost

# Public Server URL (optional - for mobile client QR codes)
# Use IP:port format (no subdomains, no path prefixes)
# Examples:
# PUBLIC_SERVER_URL=http://192.168.178.25:3000  (local network access)
# PUBLIC_SERVER_URL=http://130.60.9.82:3000     (public IP access)
# If not set, will auto-detect local network IP (may pick container IP in Docker/K8s)

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# LiveKit
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_WEBHOOK_SECRET=webhook-secret

# Use localhost for LiveKit connections (default: true)
# Set to true: Use localhost URLs (works on same machine)
# Set to false: Auto-detect network IP (for mobile/tablet access on same network)
USE_LOCALHOST=true

# Public LiveKit URL (optional - manual override for mobile client connections)
# This takes priority over USE_LOCALHOST setting
# Use IP:port format (no subdomains, no path prefixes)
# Examples:
# PUBLIC_LIVEKIT_URL=ws://192.168.178.25:7880   (local network access)
# PUBLIC_LIVEKIT_URL=ws://130.60.9.82:7880      (public IP access)
# If not set, behavior depends on USE_LOCALHOST setting above

# Kubernetes
KUBERNETES_NAMESPACE=ai-agents
AGENT_IMAGE=conversational-ai-server:latest
AGENT_IMAGE_PULL_POLICY=IfNotPresent

# OpenAI (for agents)
OPENAI_API_KEY=sk-your-openai-api-key

# TTS Provider for agents
TTS_PROVIDER=opensource
ELEVENLABS_API_KEY=your-elevenlabs-key
