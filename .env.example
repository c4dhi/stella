# ============================================================================
# GRACE AI - UNIFIED ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in your values
# ============================================================================

# ============================================================================
# ENVIRONMENT CONFIGURATION
# ============================================================================
# Environment mode: "local" or "production"
# - local: Uses localhost URLs with Kubernetes port-forwards (localhost:8080, localhost:3000, etc.)
# - production: Uses custom domains with SSL via nginx reverse proxy
NODE_ENV=local

# Production domain (base domain for all services)
# Only used when NODE_ENV=production
# Example: PRODUCTION_DOMAIN=c4dhi.moserfelix.com
# This will create: frontend.c4dhi.moserfelix.com, backend.c4dhi.moserfelix.com, etc.
PRODUCTION_DOMAIN=yourdomain.com

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# Database (local development - not used in K8s, kept for reference)
DATABASE_URL="postgresql://user:password@localhost:5432/session_management?schema=public"

# Database Credentials for Kubernetes deployment
POSTGRES_DB=session_management
POSTGRES_USER=your-db-username
POSTGRES_PASSWORD=your-secure-db-password

# ============================================================================
# SERVER CONFIGURATION (Backend - NestJS)
# ============================================================================
PORT=3000

# Public URLs - Environment specific (automatically set by deployment scripts)
# Local (NODE_ENV=local):
#   PUBLIC_FRONTEND_URL=http://localhost:8080
#   PUBLIC_API_URL=http://localhost:3000
#   PUBLIC_LIVEKIT_URL=wss://livekit-v1.c4dhi.moserfelix.com (external server)
#   PUBLIC_DB_HOST=localhost
#   PUBLIC_DB_PORT=5432
#
# Production (NODE_ENV=production):
#   PUBLIC_FRONTEND_URL=https://frontend.PRODUCTION_DOMAIN
#   PUBLIC_API_URL=https://backend.PRODUCTION_DOMAIN
#   PUBLIC_LIVEKIT_URL=wss://livekit-v1.c4dhi.moserfelix.com (external server)
#   PUBLIC_DB_HOST=db.PRODUCTION_DOMAIN
#   PUBLIC_DB_PORT=5432
#
# Note: These are set automatically by start-local.sh or start-production.sh
PUBLIC_FRONTEND_URL=http://localhost:8080
PUBLIC_API_URL=http://localhost:3000
PUBLIC_LIVEKIT_URL=wss://livekit-v1.c4dhi.moserfelix.com
PUBLIC_DB_HOST=localhost
PUBLIC_DB_PORT=5432

# CORS Configuration (automatically set to match PUBLIC_FRONTEND_URL)
CORS_ORIGIN=http://localhost:8080

# Network Access Control
# Set to 'true' to listen on all interfaces (0.0.0.0)
# Set to 'false' or omit for localhost-only (127.0.0.1) - PRODUCTION DEFAULT
ENABLE_NETWORK_ACCESS=false

# Legacy variable for backward compatibility
PUBLIC_DOMAIN=localhost

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# LiveKit - External Server Configuration
# Using external hosted LiveKit server: livekit-v1.c4dhi.moserfelix.com
# TURN server: livekit-turn.c4dhi.moserfelix.com
LIVEKIT_URL=wss://livekit-v1.c4dhi.moserfelix.com
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
LIVEKIT_WEBHOOK_SECRET=webhook-secret

# TURN Server Configuration (for NAT traversal)
LIVEKIT_TURN_ENABLED=true
LIVEKIT_TURN_DOMAIN=livekit-turn.c4dhi.moserfelix.com

# Kubernetes
KUBERNETES_NAMESPACE=ai-agents
AGENT_IMAGE=conversational-ai-server:latest
AGENT_IMAGE_PULL_POLICY=IfNotPresent

# OpenAI (for agents)
OPENAI_API_KEY=sk-your-openai-api-key

# TTS Provider for agents
TTS_PROVIDER=opensource
ELEVENLABS_API_KEY=your-elevenlabs-key
