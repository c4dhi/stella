.stella-setup-complete

# compiled output
/dist
**/node_modules/
/build

# Python compiled files
__pycache__/
*.py[cod]
*$py.class
*.so

# Python virtual environments
.venv/
venv/
ENV/
env/

# Python egg files
*.egg
*.egg-info/
dist/
build/
eggs/
.eggs/

# Logs
logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# OS
.DS_Store

# Tests
/coverage
/.nyc_output

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# dotenv environment variable files
.env
.env.local*
.env.production
.env.development.local
.env.test.local
.env.production.local

# Personal / local-only voice clips (kept out of the public repo)
tts-service/assets/voices/personal/

# temp directory
.temp
.tmp

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

/generated/prisma

# Compiled prisma seed script (generated from seed.ts)
prisma/seed.js

.claude/

# TypeScript incremental build cache
*.tsbuildinfo

# Backup bundles (#378) — contain the full deployment incl. all secrets; never commit
stella-backup-*.zip
stella-backup-*.zip.enc
