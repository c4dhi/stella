# ============================================================================
# Session Management Server API URL
# ============================================================================
# For local development (direct port access, no /api prefix):
VITE_API_URL=http://localhost:3000

# For local development with API prefix enabled:
# VITE_API_URL=http://localhost:3000/api

# For production with path-based routing (nginx reverse proxy):
# VITE_API_URL=https://yourdomain.com/api
# VITE_API_URL=https://c4dhi.moserfelix.com/api

# For production with subdomain:
# VITE_API_URL=https://api.yourdomain.com

# ============================================================================
# LiveKit Server URL (for WebRTC connections)
# ============================================================================
# Using external hosted LiveKit server instead of local instance
# Server: livekit-v1.c4dhi.moserfelix.com
# TURN: livekit-turn.c4dhi.moserfelix.com
VITE_LIVEKIT_URL=wss://livekit-v1.c4dhi.moserfelix.com

# Note: Frontend does not store API credentials directly
# Credentials are managed by session-management-server backend
# The backend generates secure JWT tokens for LiveKit connections
# ============================================================================
# Legacy: LiveKit API Credentials (not used in production)
# ============================================================================
# VITE_LIVEKIT_API_KEY=your-livekit-api-key
# VITE_LIVEKIT_API_SECRET=your-livekit-api-secret
