# ============================================================================
# Session Management Server API URL
# ============================================================================
# For local development (direct port access, no /api prefix):
VITE_API_URL=http://localhost:3000

# For local development with API prefix enabled:
# VITE_API_URL=http://localhost:3000/api

# For production with path-based routing (nginx reverse proxy):
# VITE_API_URL=https://yourdomain.com/api
# VITE_API_URL=https://c4dhi.moserfelix.com/api

# For production with subdomain:
# VITE_API_URL=https://api.yourdomain.com

# ============================================================================
# LiveKit Server URL (for WebRTC connections)
# ============================================================================
# For local development (direct port access):
VITE_LIVEKIT_URL=ws://localhost:7880

# For production with subdomain (recommended for WebSocket stability):
# VITE_LIVEKIT_URL=wss://livekit.yourdomain.com

# For production with path-based routing through nginx:
# VITE_LIVEKIT_URL=wss://yourdomain.com/livekit
# VITE_LIVEKIT_URL=wss://c4dhi.moserfelix.com/livekit

# ============================================================================
# LiveKit API Credentials
# ============================================================================
VITE_LIVEKIT_API_KEY=devkey
VITE_LIVEKIT_API_SECRET=secret
