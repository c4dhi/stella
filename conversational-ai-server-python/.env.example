# LiveKit Configuration
LIVEKIT_URL=ws://localhost:7880
ROOM_NAME=test-room
IDENTITY=python-listener
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# TTS Provider Configuration
# Options: "opensource" or "elevenlabs"
# NOTE: TTS_PROVIDER selection is handled in main.py
TTS_PROVIDER=opensource

# ElevenLabs Configuration (required only if TTS_PROVIDER=elevenlabs)
# Get your API key from https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional ElevenLabs settings (all read from .env)
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM  # Rachel voice (default)
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5     # Fast model for streaming
ELEVENLABS_STABILITY=0.5                  # Voice stability (0.0-1.0)
ELEVENLABS_SIMILARITY_BOOST=0.8           # Voice similarity (0.0-1.0)
ELEVENLABS_STYLE=0.0                      # Style exaggeration (0.0-1.0)
ELEVENLABS_USE_SPEAKER_BOOST=true         # Speaker boost (true/false)

# Kokoro TTS Configuration (for opensource provider)
# Optional - will auto-download models if not specified
KOKORO_MODEL_PATH=./kokoro-models/kokoro-v1.0.onnx
KOKORO_VOICES_PATH=./kokoro-models/voices-v1.0.bin
KOKORO_CACHE_DIR=/root/.cache/kokoro

# STT Provider Configuration (100% Local/Opensource, Container-Compatible)
# Options: "sherpa" (default, lightweight) or "faster-whisper" (more accurate, requires more CPU)
# NOTE: STT_PROVIDER selection is handled in main.py
STT_PROVIDER=sherpa

# faster-whisper Configuration (Container-Compatible, No pvporcupine)
# Uses faster-whisper for transcription and Silero VAD for turn detection
# Model options: tiny.en, base.en, small.en, medium.en, large-v3
# tiny.en: ~75MB, fastest, ~85% accuracy (10x faster than small.en - good for real-time)
# base.en: ~140MB, fast, ~88% accuracy (5x faster than small.en - RECOMMENDED for production)
# small.en: ~460MB, balanced, ~91% accuracy (good for accuracy, slower on CPU)
# medium.en: ~1.5GB, slow, ~94% accuracy
# large-v3: ~2.9GB, slowest, ~96% accuracy
WHISPER_MODEL=base.en

# Device: "cpu" or "cuda" (GPU acceleration if available)
WHISPER_DEVICE=cpu

# Compute type: "int8" (CPU optimized) or "float16" (GPU optimized)
WHISPER_COMPUTE_TYPE=int8

# Transcription optimization (for real-time/CPU efficiency in Kubernetes)
# beam_size: 1=greedy decoding (3-5x faster), 5=beam search (more accurate but slow)
# word_timestamps: false=faster (1.5-2x), true=slower (adds word-level timing)
WHISPER_BEAM_SIZE=1
WHISPER_WORD_TIMESTAMPS=false

# Silero VAD Configuration
VAD_THRESHOLD=0.5                    # Speech probability threshold (0.0-1.0)
VAD_MIN_SPEECH_MS=250               # Minimum speech duration in ms
VAD_MIN_SILENCE_MS=500              # Minimum silence for endpoint in ms

# Streaming Configuration
ENABLE_STREAMING_CHUNKS=true        # Enable chunk-based partial results
CHUNK_LENGTH_MS=1000                # Process audio every 1000ms (1 second)
PARTIAL_TRANSCRIPT_INTERVAL_MS=1000 # Send partial transcripts every N ms while speaking (real-time feedback)

# Barge-in Configuration
# These settings control interruption detection during TTS playback
MIN_INTERRUPTION_DURATION=0.5        # Minimum speech duration to trigger barge-in (500ms)
MIN_INTERRUPTION_WORDS=1             # Minimum words needed for valid interruption
FALSE_INTERRUPTION_TIMEOUT=2.0       # Time to wait before abandoning false interruption (2s)