{
  "default_plan": "cognitive_stimulation_demo_sm",
  "plan_settings": {
    "auto_advance_statements": true,
    "require_explicit_completion": false,
    "task_strictness": "moderate",
    "confidence_threshold": {
      "required_deliverables": 0.7,
      "optional_deliverables": 0.5
    },
    "retry_attempts": {
      "max_deliverable_retries": 3,
      "retry_delay_seconds": 0
    }
  },
  "plans": {
    "cognitive_stimulation_demo_sm": {
      "description": "GRACE cognitive stimulation exercise with memory game using state machine",
      "enabled": true,
      "fallback_plan": null,
      "custom_settings": {
        "grace_personality": "friendly_and_curious",
        "memory_game_items": ["milk", "bread", "eggs", "apples", "cheese", "butter", "chicken", "rice", "tomatoes", "bananas"],
        "max_memory_levels": 10,
        "task_strictness": "strict"
      }
    }
  },
  "task_strictness_definitions": {
    "loose": "General conversation, flexible task following, allows digressions and off-topic responses",
    "moderate": "Guided conversation with some flexibility, gentle redirection to plan goals",
    "strict": "Rigid step ordering, minimal deviation allowed, strong enforcement of plan progression (ideal for games and structured exercises)"
  },
  "deliverable_detection": {
    "name_validation": {
      "min_length": 2,
      "max_length": 50,
      "allow_special_chars": false
    },
    "enum_matching": {
      "case_sensitive": false,
      "partial_match": true
    },
    "string_extraction": {
      "max_length": 500,
      "require_substantive": true
    }
  },
  "integration": {
    "send_plan_updates": true,
    "include_deliverable_states": true,
    "notify_step_changes": true,
    "update_triggers": [
      "plan_start",
      "step_advance",
      "deliverable_completed",
      "plan_completed"
    ]
  }
}