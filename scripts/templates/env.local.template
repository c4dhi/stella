# ============================================================================
# STELLA - LOCAL DEVELOPMENT CONFIGURATION
# ============================================================================
# Template for local development (macOS/OrbStack)
# Variables marked @required must be set before starting
# Run LiveKit locally: docker run -d -p 7880:7880 livekit/livekit-server --dev
# ============================================================================

# ─── DATABASE ───────────────────────────────────────────────────────────────
# @required
POSTGRES_DB=session_management
# @required
POSTGRES_USER=postgres
# @required - Set a secure password
POSTGRES_PASSWORD=

# ─── SECURITY ───────────────────────────────────────────────────────────────
# @required - App will not start without JWT_SECRET
# Generate with: openssl rand -base64 48
JWT_SECRET=
# @required - Encrypts env vars in database (without: stored as readable base64)
# Generate with: openssl rand -hex 32
ENV_VAR_ENCRYPTION_KEY=

# ─── LIVEKIT (WebRTC) ───────────────────────────────────────────────────────
# @required
LIVEKIT_API_KEY=devkey
# @required - LiveKit local default secret (32 chars)
LIVEKIT_API_SECRET=devsecret_devsecret_devsecret_32!!
# @required - Internal URL for K8s pods (host.docker.internal for Docker on host)
LIVEKIT_URL=ws://host.docker.internal:7880
# @required - External URL for browsers
PUBLIC_LIVEKIT_URL=ws://localhost:7880
LIVEKIT_TURN_ENABLED=false
LIVEKIT_TURN_DOMAIN=

# ─── AI APIs ────────────────────────────────────────────────────────────────
# @required
OPENAI_API_KEY=
# Optional - Separate key for plan generation
OPENAI_PLAN_GENERATOR_API_KEY=
# Optional - Only if using ElevenLabs TTS
ELEVENLABS_API_KEY=

# ─── SPEECH-TO-TEXT (STT) ───────────────────────────────────────────────────
# Provider: sherpa (lightweight CPU) or whisper (GPU-accelerated)
STT_PROVIDER=sherpa
# Whisper settings (only used when STT_PROVIDER=whisper)
WHISPER_MODEL=base.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=5
WHISPER_LANGUAGE=
# Voice Activity Detection
VAD_THRESHOLD=0.5
VAD_SILENCE_DURATION_MS=800
VAD_CONTINUATION_WINDOW_MS=1000
VAD_MAX_ENDPOINTING_DELAY_MS=2000
VAD_MIN_SPEECH_MS=500
VAD_MAX_SPEECH_DURATION_MS=30000
VAD_AUDIO_INACTIVITY_TIMEOUT_MS=1500
VAD_RMS_THRESHOLD=0.008
PARTIAL_INTERVAL_MS=1000

# ─── TEXT-TO-SPEECH (TTS) ───────────────────────────────────────────────────
# Provider: piper (local), kokoro (local GPU), elevenlabs (premium)
TTS_PROVIDER=piper
ELEVENLABS_VOICE_ID=Xb7hH8MSUJpSbSDYk0k2
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# ─── GPU ACCELERATION ───────────────────────────────────────────────────────
# macOS: No NVIDIA support, keep disabled
ENABLE_GPU=false
ONNX_PROVIDER=CPUExecutionProvider

# ─── KUBERNETES ─────────────────────────────────────────────────────────────
KUBERNETES_NAMESPACE=ai-agents
# Local dev typically doesn't need custom DNS
CUSTOM_DNS_SERVERS=
AUTO_DETECT_K8S_DNS=false

# ─── ENVIRONMENT ────────────────────────────────────────────────────────────
NODE_ENV=local
