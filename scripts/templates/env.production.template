# ============================================================================
# STELLA - PRODUCTION CONFIGURATION
# ============================================================================
# Template for production deployment (Ubuntu/K3s with GPU)
# Variables marked @required must be set before starting
# Generate secrets: openssl rand -base64 48 (JWT) or openssl rand -hex 32 (key)
# ============================================================================

# ─── DATABASE ───────────────────────────────────────────────────────────────
# @required
POSTGRES_DB=session_management
# @required
POSTGRES_USER=postgres
# @required - Use a strong, unique password
POSTGRES_PASSWORD=

# ─── SECURITY ───────────────────────────────────────────────────────────────
# @required - Generate with: openssl rand -base64 48
JWT_SECRET=
# @required - Generate with: openssl rand -hex 32 (must be exactly 64 hex chars)
ENV_VAR_ENCRYPTION_KEY=

# ─── LIVEKIT (WebRTC) ───────────────────────────────────────────────────────
# @required
LIVEKIT_API_KEY=
# @required - Generate a secure secret
LIVEKIT_API_SECRET=
# @required - Internal URL: ws://<YOUR_HOST_IP>:7880 (NOT wss!)
LIVEKIT_URL=
# @required - Public URL with SSL: wss://livekit.yourdomain.com
PUBLIC_LIVEKIT_URL=
# TURN server for NAT traversal (recommended for production)
LIVEKIT_TURN_ENABLED=true
LIVEKIT_TURN_DOMAIN=

# ─── AI APIs ────────────────────────────────────────────────────────────────
# @required
OPENAI_API_KEY=
# Optional - Separate key for plan generation (cost isolation)
OPENAI_PLAN_GENERATOR_API_KEY=
# Optional - Only if using ElevenLabs TTS
ELEVENLABS_API_KEY=

# ─── SPEECH-TO-TEXT (STT) ───────────────────────────────────────────────────
# Production with GPU: whisper for best accuracy
STT_PROVIDER=whisper
# Whisper settings for GPU
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
WHISPER_BEAM_SIZE=3
WHISPER_LANGUAGE=
# Voice Activity Detection (tuned for production)
VAD_THRESHOLD=0.35
VAD_SILENCE_DURATION_MS=800
VAD_CONTINUATION_WINDOW_MS=1000
VAD_MAX_ENDPOINTING_DELAY_MS=2000
VAD_MIN_SPEECH_MS=200
VAD_MAX_SPEECH_DURATION_MS=30000
VAD_AUDIO_INACTIVITY_TIMEOUT_MS=1500
VAD_RMS_THRESHOLD=0.008
PARTIAL_INTERVAL_MS=500

# ─── TEXT-TO-SPEECH (TTS) ───────────────────────────────────────────────────
# Production with GPU: kokoro for lowest latency
TTS_PROVIDER=kokoro
ELEVENLABS_VOICE_ID=Xb7hH8MSUJpSbSDYk0k2
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# ─── GPU ACCELERATION ───────────────────────────────────────────────────────
# Production: Enable for NVIDIA GPU (Tesla T4, RTX, etc.)
ENABLE_GPU=true
ONNX_PROVIDER=CUDAExecutionProvider,CPUExecutionProvider

# ─── KUBERNETES ─────────────────────────────────────────────────────────────
KUBERNETES_NAMESPACE=ai-agents
# Google DNS to bypass corporate SSL inspection
CUSTOM_DNS_SERVERS=8.8.8.8 8.8.4.4
AUTO_DETECT_K8S_DNS=false
KUBERNETES_DNS_NAMESERVER=10.96.0.10

# ─── PRODUCTION ─────────────────────────────────────────────────────────────
# @required - Your production domain (e.g., example.com)
# DNS / reverse-proxy convention (point both records at this host):
#   <domain>          -> frontend  (the APEX serves the UI, NOT frontend.<domain>)
#   backend.<domain>  -> API
# CORS is derived automatically from the frontend URL, so it can never drift.
# Override PUBLIC_FRONTEND_URL / PUBLIC_API_URL only if your DNS differs.
PRODUCTION_DOMAIN=
# Base dir for ALL heavy storage: Docker build cache + images, the K3s/
# containerd image store, and the model/database volumes. Leave BLANK to use
# system defaults (/var/lib/docker, /var/lib/rancher/k3s, /tmp) — always works.
# Point it at a mounted disk to run everything from there when the internal
# disk is too small, e.g.:
#   STELLA_DATA_ROOT=/mnt/stella
# Note: K3s relocation only applies on a fresh install (see docs).
STELLA_DATA_ROOT=
# Temp dir for builds/logs. Blank = STELLA_DATA_ROOT/tmp (if set) or /tmp.
STELLA_AI_TEMP_DIR=

# ─── ENVIRONMENT ────────────────────────────────────────────────────────────
NODE_ENV=production
